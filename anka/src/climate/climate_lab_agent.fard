import("std/http") as http
import("std/json") as json
import("std/str") as str
import("std/list") as list
import("std/rec") as rec
import("std/datetime") as dt

// Climate Lab Agent
// Role: publish research findings and model training traces.
// Subscribes to: research.result.claims, model.training.trace
// Publishes to:  research.result.claims, model.training.trace
//
// Deliberation: publish findings with dataset provenance citations.
// Does not witness own claims. Ignores claims from same institution.

fn make_dalil(node_address) {
  {
    compose: fn(addr, cs, subj, finding, refs, ts) {
      let result = http.post(str.concat([addr, "/publish"]), json.encode({
        claim_space: cs, subject: subj, predicate: "reported_finding",
        object: finding, evidence_refs: refs, timestamp_unix_secs: ts
      })) in
      if result.status == 200 then
        let d = json.decode(result.body) in
        { ok: true, digest_hex: d.digest_hex, cite_as: str.concat(["anka:", d.digest_hex]) }
      else { ok: false, reason: "publish failed" }
    },
    post_node: fn(addr, path, body) {
      let result = http.post(str.concat([addr, path]), json.encode(body)) in
      if result.status == 200 then { ok: true, data: json.decode(result.body) }
      else { ok: false }
    }
  }
}

fn publish_finding(node_address, subject, finding, dataset_refs, timestamp) {
  let dalil = make_dalil(node_address) in
  dalil.compose(node_address, "research.result.claims", subject, finding, dataset_refs, timestamp)
}

fn publish_model_trace(node_address, model_id, training_summary, dataset_refs, timestamp) {
  let dalil = make_dalil(node_address) in
  dalil.compose(node_address, "model.training.trace", model_id, training_summary, dataset_refs, timestamp)
}

fn run(node_address, institution, findings, timestamp) {
  let results = list.map(findings, fn(f) {
    let finding_result = publish_finding(node_address, f.subject, f.finding, f.dataset_refs, timestamp) in
    let trace_result = publish_model_trace(node_address, f.model_id, f.training_summary, [finding_result.digest_hex], timestamp + 1) in
    {
      subject: f.subject,
      finding_digest: finding_result.digest_hex,
      trace_digest: trace_result.digest_hex,
      ok: finding_result.ok && trace_result.ok
    }
  }) in
  {
    ok: true,
    agent: "climate-lab",
    institution: institution,
    node_address: node_address,
    published_count: list.len(list.filter(results, fn(r) { r.ok })),
    results: results
  }
}

export { make_dalil, publish_finding, publish_model_trace, run }
