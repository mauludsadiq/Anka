fn html() {
  "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>ANKA Observer</title>\n<style>\n:root{\n  --bg:#f4f6f9;--surface:#ffffff;--surface2:#f0f2f5;\n  --border:#dde1e7;--border2:#c8cdd6;\n  --text:#5a6475;--bright:#1a2232;--dim:#9aa3b0;\n  --accent:#1a56db;--accent2:#0891b2;--warn:#d97706;--error:#dc2626;--success:#059669;\n  --sans:-apple-system,BlinkMacSystemFont,'Helvetica Neue',Helvetica,Arial,sans-serif;\n}\n*{box-sizing:border-box;margin:0;padding:0;}\nbody{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:13px;line-height:1.5;min-height:100vh;}\nheader{background:var(--surface);border-bottom:1px solid var(--border);padding:0 28px;display:flex;align-items:center;justify-content:space-between;height:52px;}\n.logo{font-size:13px;font-weight:600;color:var(--bright);letter-spacing:.04em;display:flex;align-items:center;gap:8px;}\n.logo-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);}\n.header-right{display:flex;align-items:center;gap:12px;font-size:12px;color:var(--dim);}\n.pulse{width:6px;height:6px;border-radius:50%;background:var(--success);animation:pulse 2s infinite;}\n@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}\n.stat-bar{background:var(--surface);border-bottom:1px solid var(--border);display:grid;grid-template-columns:repeat(6,1fr);}\n.stat{padding:14px 20px;border-right:1px solid var(--border);}\n.stat:last-child{border-right:none;}\n.sl{font-size:11px;font-weight:500;color:var(--dim);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;}\n.sv{font-size:26px;font-weight:300;color:var(--bright);}\n.sv.a{color:var(--accent);}\n.sv.b{color:var(--accent2);}\n.sv.w{color:var(--warn);}\n.sv.g{color:var(--success);}\nmain{padding:20px 24px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;}\n.panel{background:var(--surface);border:1px solid var(--border);border-radius:4px;overflow:hidden;}\n.panel.wide{grid-column:span 2;}\n.panel.full{grid-column:span 3;}\n.ph{font-size:11px;font-weight:600;color:var(--bright);padding:10px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;background:var(--surface2);letter-spacing:.03em;text-transform:uppercase;}\n.ph em{color:var(--accent);font-style:normal;font-size:11px;font-weight:400;text-transform:none;letter-spacing:0;}\n.pb{padding:14px 16px;}\n.rows{display:flex;flex-direction:column;}\n.row{padding:8px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;font-size:12px;}\n.row:last-child{border-bottom:none;}\n.row:hover{background:var(--surface2);}\n.dig{color:var(--accent);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px;font-family:ui-monospace,monospace;}\n.tag{font-size:10px;padding:2px 7px;border-radius:3px;font-weight:500;white-space:nowrap;}\n.tag.inv{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;}\n.tag.int{background:#fffbeb;color:#92400e;border:1px solid #fde68a;}\n.tag.ok{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;}\n.tag.err{background:#fef2f2;color:#991b1b;border:1px solid #fecaca;}\n.peer-row{padding:9px 16px;border-bottom:1px solid var(--border);display:grid;grid-template-columns:1fr auto;gap:8px;align-items:center;font-size:12px;}\n.peer-addr{color:var(--bright);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.peer-status{font-size:10px;padding:2px 8px;border-radius:3px;font-weight:500;}\n.peer-ok{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;}\n.peer-err{background:#fef2f2;color:#991b1b;border:1px solid #fecaca;}\n.space-grid{display:grid;grid-template-columns:1fr 1fr;}\n.space-item{padding:9px 12px;border-bottom:1px solid var(--border);border-right:1px solid var(--border);}\n.space-item:nth-child(even){border-right:none;}\n.space-name{color:var(--bright);font-size:11px;font-weight:500;margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.space-meta{font-size:10px;color:var(--dim);}\n.claim-row{padding:9px 16px;border-bottom:1px solid var(--border);display:grid;grid-template-columns:80px 1fr 1fr 120px;gap:10px;align-items:center;font-size:12px;}\n.claim-row:last-child{border-bottom:none;}\n.claim-row:hover{background:var(--surface2);}\n.claim-space{font-size:10px;color:var(--dim);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.claim-subject{color:var(--bright);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.claim-value{color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.claim-dig{font-family:ui-monospace,monospace;font-size:10px;color:var(--accent);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.event-row{padding:7px 16px;border-bottom:1px solid var(--border);display:grid;grid-template-columns:72px 130px 1fr 54px;gap:10px;align-items:center;font-size:11px;}\n.event-row:last-child{border-bottom:none;}\n.ev-kind{font-size:10px;padding:2px 7px;border-radius:3px;font-weight:500;text-align:center;}\n.ev-pub{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;}\n.ev-wit{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;}\n.ev-cha{background:#fffbeb;color:#92400e;border:1px solid #fde68a;}\n.ev-dig{font-family:ui-monospace,monospace;color:var(--dim);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.ev-data{color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.ev-time{color:var(--dim);text-align:right;white-space:nowrap;}\n.conv-bar{height:3px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:8px;}\n.conv-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .5s;}\n.empty{color:var(--dim);padding:16px;font-size:12px;}\n.kv-grid{display:flex;flex-direction:column;}\n.kv-row{padding:8px 16px;border-bottom:1px solid var(--border);display:grid;grid-template-columns:140px 1fr;gap:8px;font-size:12px;}\n.kv-row:last-child{border-bottom:none;}\n.kv-k{color:var(--dim);}\n.kv-v{color:var(--bright);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.topo-canvas{padding:20px 16px;min-height:110px;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;}\n.node-box{border:1px solid var(--border2);background:var(--surface2);padding:10px 16px;border-radius:4px;text-align:center;min-width:110px;}\n.node-box.self{border-color:var(--accent);background:#eff6ff;}\n.nb-label{font-size:10px;font-weight:600;color:var(--dim);text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px;}\n.nb-id{font-size:10px;color:var(--bright);font-family:ui-monospace,monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100px;}\n.nb-dot{width:5px;height:5px;border-radius:50%;background:var(--success);margin:5px auto 0;}\n.edge{color:var(--border2);font-size:20px;align-self:center;}\n.metric-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;}\n.metric-item{padding:12px 16px;border-bottom:1px solid var(--border);border-right:1px solid var(--border);}\n.metric-item:nth-child(even){border-right:none;}\n.metric-item:nth-last-child(-n+2){border-bottom:none;}\n.metric-label{font-size:10px;color:var(--dim);text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px;}\n.metric-value{font-size:20px;font-weight:300;color:var(--bright);}\n.metric-value.up{color:var(--accent);}\n.metric-value.ok{color:var(--success);}\n.index-row{padding:8px 16px;border-bottom:1px solid var(--border);display:grid;grid-template-columns:1fr 60px 60px;gap:8px;align-items:center;font-size:11px;}\n.index-row:last-child{border-bottom:none;}\n.index-space{color:var(--bright);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.index-num{color:var(--accent);text-align:right;font-family:ui-monospace,monospace;}\n</style>\n</head>\n<body>\n<header>\n  <div class=\"logo\"><div class=\"logo-dot\"></div>ANKA Observer</div>\n  <div class=\"header-right\">\n    <span id=\"node-id-short\">connecting...</span>\n    <span id=\"uptime-label\" style=\"font-size:11px;\"></span>\n    <div class=\"pulse\" id=\"pulse\" style=\"background:var(--dim)\"></div>\n  </div>\n</header>\n\n<div class=\"stat-bar\">\n  <div class=\"stat\"><div class=\"sl\">Claims</div><div class=\"sv a\" id=\"s-claims\">-</div></div>\n  <div class=\"stat\"><div class=\"sl\">Witnesses</div><div class=\"sv b\" id=\"s-witnesses\">-</div></div>\n  <div class=\"stat\"><div class=\"sl\">Challenges</div><div class=\"sv w\" id=\"s-challenges\">-</div></div>\n  <div class=\"stat\"><div class=\"sl\">Peers</div><div class=\"sv\" id=\"s-peers\">-</div></div>\n  <div class=\"stat\"><div class=\"sl\">Index Spaces</div><div class=\"sv g\" id=\"s-spaces\">-</div></div>\n  <div class=\"stat\"><div class=\"sl\">Fed Meshes</div><div class=\"sv\" id=\"s-meshes\">-</div></div>\n</div>\n\n<main>\n  <div class=\"panel wide\">\n    <div class=\"ph\"><span>Node Topology</span><em id=\"topo-status\"></em></div>\n    <div class=\"topo-canvas\" id=\"topo\"></div>\n  </div>\n\n  <div class=\"panel\">\n    <div class=\"ph\"><span>Node Identity</span><em id=\"health-status\"></em></div>\n    <div class=\"kv-grid\" id=\"identity\"></div>\n  </div>\n\n  <div class=\"panel full\">\n    <div class=\"ph\"><span>Metrics</span><em id=\"metrics-ts\"></em></div>\n    <div class=\"metric-grid\" id=\"metric-grid\">\n      <div class=\"metric-item\"><div class=\"metric-label\">Claims Published</div><div class=\"metric-value up\" id=\"m-published\">-</div></div>\n      <div class=\"metric-item\"><div class=\"metric-label\">Witnesses Recorded</div><div class=\"metric-value ok\" id=\"m-witnesses\">-</div></div>\n      <div class=\"metric-item\"><div class=\"metric-label\">Gossip Sent</div><div class=\"metric-value\" id=\"m-gossip-sent\">-</div></div>\n      <div class=\"metric-item\"><div class=\"metric-label\">Gossip Received</div><div class=\"metric-value\" id=\"m-gossip-recv\">-</div></div>\n      <div class=\"metric-item\"><div class=\"metric-label\">Index Spaces</div><div class=\"metric-value\" id=\"m-idx-spaces\">-</div></div>\n      <div class=\"metric-item\"><div class=\"metric-label\">Index Claims</div><div class=\"metric-value\" id=\"m-idx-claims\">-</div></div>\n      <div class=\"metric-item\"><div class=\"metric-label\">Fed Meshes</div><div class=\"metric-value\" id=\"m-fed-meshes\">-</div></div>\n      <div class=\"metric-item\"><div class=\"metric-label\">Rep Nodes Tracked</div><div class=\"metric-value\" id=\"m-rep-nodes\">-</div></div>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <div class=\"ph\"><span>Index</span><em id=\"index-status\"></em></div>\n    <div id=\"index-rows\"><div class=\"empty\">Loading...</div></div>\n  </div>\n\n  <div class=\"panel\">\n    <div class=\"ph\"><span>Registry</span><em id=\"reg-ver\"></em></div>\n    <div class=\"space-grid\" id=\"space-grid\"><div class=\"empty\" style=\"grid-column:span 2\">Loading...</div></div>\n  </div>\n\n  <div class=\"panel\">\n    <div class=\"ph\"><span>Peers</span></div>\n    <div id=\"peer-rows\"><div class=\"empty\">Loading...</div></div>\n  </div>\n\n  <div class=\"panel wide\">\n    <div class=\"ph\"><span>Claims</span><em id=\"claim-count\"></em></div>\n    <div class=\"rows\" id=\"claim-rows\"><div class=\"empty\">Loading...</div></div>\n  </div>\n\n  <div class=\"panel full\">\n    <div class=\"ph\"><span>Audit Feed</span><em id=\"audit-count\"></em></div>\n    <div class=\"rows\" id=\"audit-rows\"><div class=\"empty\">Loading...</div></div>\n  </div>\n\n  <div class=\"panel wide\">\n    <div class=\"ph\"><span>Convergence</span><em id=\"conv-status\"></em></div>\n    <div class=\"pb\">\n      <div id=\"conv-detail\" style=\"font-size:12px;color:var(--text);margin-bottom:6px;\">Checking...</div>\n      <div class=\"conv-bar\"><div class=\"conv-fill\" id=\"conv-fill\" style=\"width:0%\"></div></div>\n    </div>\n    <div class=\"rows\" id=\"known-rows\"></div>\n  </div>\n\n  <div class=\"panel full\" id=\"graph-panel\" style=\"display:none\">\n    <div class=\"ph\"><span>Claim Graph</span><em id=\"graph-digest\"></em><button id=\"graph-close\" style=\"font-size:10px;color:var(--dim);border:none;background:none;cursor:pointer;font-family:var(--sans);margin-left:auto\">Close</button></div>\n    <div class=\"kv-grid\" id=\"graph-content\"></div>\n  </div>\n</main>\n\n<script>\nvar BASE = window.location.origin;\nvar SELF_ID = '';\nvar AUDIT_EVENTS = [];\nvar LOAD_START = Date.now();\n\nfunction get(path, cb) {\n  fetch(BASE + path).then(function(r){return r.json();}).then(cb).catch(function(){});\n}\n\nfunction short(s) {\n  if (!s) return '-';\n  if (s.length > 22) return s.slice(0,10)+'...'+s.slice(-6);\n  return s;\n}\n\nfunction timeStr(ts) {\n  if (!ts) return '';\n  return new Date(ts*1000).toISOString().slice(11,19)+' UTC';\n}\n\nfunction kv(pairs) {\n  return pairs.map(function(p){\n    return '<div class=\"kv-row\"><div class=\"kv-k\">'+p[0]+'</div><div class=\"kv-v\">'+p[1]+'</div></div>';\n  }).join('');\n}\n\nfunction isInvariant(space) {\n  return ['invariant','crypto','compute','provenance','trace','receipts','reproducibility'].some(function(k){return space.indexOf(k)>=0;});\n}\n\nfunction load() {\n  var elapsed = Math.floor((Date.now() - LOAD_START) / 1000);\n  document.getElementById('uptime-label').textContent = 'up ' + elapsed + 's';\n\n  get('/health', function(h) {\n    if (!h) { document.getElementById('pulse').style.background='var(--error)'; return; }\n    document.getElementById('pulse').style.background='var(--success)';\n    SELF_ID = h.node_id || '';\n    document.getElementById('node-id-short').textContent = short(SELF_ID);\n    document.getElementById('s-claims').textContent = h.claim_count || 0;\n    document.getElementById('s-witnesses').textContent = h.witness_count || 0;\n    document.getElementById('s-challenges').textContent = h.challenge_count || 0;\n    document.getElementById('s-peers').textContent = h.peer_count || 0;\n    document.getElementById('s-spaces').textContent = (h.index && h.index.spaces) || 0;\n    document.getElementById('s-meshes').textContent = (h.federation && h.federation.registered_meshes) || 0;\n    var idx = h.index || {};\n    document.getElementById('health-status').textContent = idx.fresh ? 'Index fresh' : 'Index building';\n    document.getElementById('identity').innerHTML = kv([\n      ['Node ID', short(SELF_ID)],\n      ['Status', 'Online'],\n      ['Claims', h.claim_count || 0],\n      ['Witnesses', h.witness_count || 0],\n      ['Index Spaces', idx.spaces || 0],\n      ['Fed Meshes', (h.federation && h.federation.registered_meshes) || 0],\n      ['Rep Nodes', h.reputation_nodes || 0],\n      ['Snapshots', (h.archive && h.archive.snapshot_count) || 0]\n    ]);\n  });\n\n  get('/metrics', function(m) {\n    if (!m) return;\n    var c = m.counters || {};\n    var idx = m.index || {};\n    var fed = m.federation || {};\n    document.getElementById('m-published').textContent = c.claims_published || 0;\n    document.getElementById('m-witnesses').textContent = c.witnesses_recorded || 0;\n    document.getElementById('m-gossip-sent').textContent = c.gossip_sent || 0;\n    document.getElementById('m-gossip-recv').textContent = c.gossip_received || 0;\n    document.getElementById('m-idx-spaces').textContent = idx.total_spaces || 0;\n    document.getElementById('m-idx-claims').textContent = idx.total_claims_indexed || 0;\n    document.getElementById('m-fed-meshes').textContent = fed.registered_meshes || 0;\n    document.getElementById('m-rep-nodes').textContent = (m.reputation && m.reputation.tracked_nodes) || 0;\n    document.getElementById('metrics-ts').textContent = new Date().toISOString().slice(11,19)+' UTC';\n    var spaces = idx.spaces || [];\n    var el = document.getElementById('index-rows');\n    document.getElementById('index-status').textContent = spaces.length + ' spaces';\n    if (spaces.length === 0) { el.innerHTML = '<div class=\"empty\">No indexed spaces</div>'; return; }\n    el.innerHTML = '<div class=\"index-row\" style=\"font-size:10px;color:var(--dim);font-weight:600;\"><span>CLAIM SPACE</span><span style=\"text-align:right\">SUBJECTS</span><span style=\"text-align:right\">CLAIMS</span></div>' +\n      spaces.map(function(s) {\n        return '<div class=\"index-row\"><div class=\"index-space\">'+s.claim_space+'</div><div class=\"index-num\">'+s.subject_count+'</div><div class=\"index-num\">'+s.claim_count+'</div></div>';\n      }).join('');\n  });\n\n  get('/peers', function(p) {\n    if (!p) return;\n    var pl = p.peers || [];\n    var topo = document.getElementById('topo');\n    var html = '<div class=\"node-box self\"><div class=\"nb-label\">This Node</div><div class=\"nb-id\">'+short(SELF_ID)+'</div><div class=\"nb-dot\"></div></div>';\n    pl.forEach(function(addr) {\n      html += '<span class=\"edge\">&#8594;</span>';\n      html += '<div class=\"node-box\"><div class=\"nb-label\">Peer</div><div class=\"nb-id\">'+addr.replace(/https?:\\/\\//,'')+'</div><div class=\"nb-dot\"></div></div>';\n    });\n    if (pl.length === 0) html += '<span style=\"color:var(--dim);font-size:12px;margin-left:16px\">No peers connected</span>';\n    topo.innerHTML = html;\n    document.getElementById('topo-status').textContent = pl.length + ' connected';\n    var el = document.getElementById('peer-rows');\n    if (pl.length === 0) { el.innerHTML = '<div class=\"empty\">No peers</div>'; return; }\n    Promise.all(pl.map(function(addr){\n      return fetch(addr+'/health').then(function(r){return r.ok?'ok':'err';}).catch(function(){return 'err';});\n    })).then(function(statuses) {\n      el.innerHTML = pl.map(function(addr,i){\n        var ok = statuses[i]==='ok';\n        return '<div class=\"peer-row\"><div class=\"peer-addr\">'+addr+'</div><span class=\"peer-status '+(ok?'peer-ok':'peer-err')+'\">'+(ok?'Online':'Unreachable')+'</span></div>';\n      }).join('');\n    });\n  });\n\n  get('/registry', function(r) {\n    if (!r) return;\n    var sp = r.known_spaces || [];\n    var reg = r.registry || {};\n    document.getElementById('reg-ver').textContent = 'Version ' + (reg.version || 0);\n    var el = document.getElementById('space-grid');\n    if (sp.length === 0) { el.innerHTML = '<div class=\"empty\" style=\"grid-column:span 2\">No spaces registered</div>'; return; }\n    el.innerHTML = sp.map(function(s) {\n      var inv = isInvariant(s);\n      return '<div class=\"space-item\"><div class=\"space-name\">'+s+'</div><div class=\"space-meta\">'+(inv?'Invariant':'Interpretive')+'</div></div>';\n    }).join('');\n  });\n\n  get('/known', function(k) {\n    if (!k) return;\n    var digests = k.known_digests || [];\n    document.getElementById('claim-count').textContent = digests.length + ' claims';\n    document.getElementById('conv-detail').textContent = digests.length + ' known digests on this node';\n    document.getElementById('conv-fill').style.width = Math.min(100, digests.length * 4) + '%';\n    document.getElementById('conv-status').textContent = digests.length > 0 ? 'Active' : 'Empty';\n    var kr = document.getElementById('known-rows');\n    if (digests.length === 0) { kr.innerHTML = '<div class=\"empty\">No digests</div>'; }\n    else {\n      kr.innerHTML = digests.slice(0,8).map(function(d){\n        return '<div class=\"row\"><div class=\"dig\">'+d+'</div></div>';\n      }).join('') + (digests.length > 8 ? '<div class=\"row\"><div style=\"color:var(--dim);font-size:11px\">+ '+(digests.length-8)+' more</div></div>' : '');\n    }\n    var claimRows = [];\n    var pending = digests.slice(0,20);\n    if (pending.length === 0) { document.getElementById('claim-rows').innerHTML = '<div class=\"empty\">No claims yet</div>'; return; }\n    var fetched = 0;\n    pending.forEach(function(dig) {\n      get('/claim/'+dig, function(c) {\n        fetched++;\n        if (c && c.ok && c.envelope) {\n          var cl = c.envelope.claim;\n          claimRows.push({dig:dig, space:cl.claim_space||'', subj:cl.subject||'', val:cl.object||'', inv:isInvariant(cl.claim_space||'')});\n          get('/audit/trail/local/'+dig, function(t) {\n            if (!t || !t.history) return;\n            (t.history.trail||[]).forEach(function(ev){\n              AUDIT_EVENTS.push({kind:ev.event_kind, dig:dig, ts:ev.timestamp_unix_secs, data:ev.event_data});\n            });\n            AUDIT_EVENTS.sort(function(a,b){return b.ts-a.ts;});\n            renderAudit();\n          });\n        }\n        if (fetched === pending.length) renderClaims(claimRows);\n      });\n    });\n  });\n}\n\nvar DIGESTS = [];\nfunction renderClaims(rows) {\n  var el = document.getElementById('claim-rows');\n  if (rows.length === 0) { el.innerHTML = '<div class=\"empty\">No claims</div>'; return; }\n  DIGESTS = rows.map(function(r){return r.dig;});\n  el.innerHTML = rows.map(function(r,i) {\n    return '<div class=\"claim-row\" onclick=\"loadGraph(DIGESTS['+i+'])\" style=\"cursor:pointer\">'+\n      '<span class=\"tag '+(r.inv?'inv':'int')+'\">'+(r.inv?'Invariant':'Interpretive')+'</span>'+\n      '<div><div class=\"claim-subject\">'+r.subj+'</div><div class=\"claim-space\">'+r.space+'</div></div>'+\n      '<div class=\"claim-value\">'+r.val+'</div>'+\n      '<div class=\"claim-dig\">'+short(r.dig)+'</div>'+\n      '</div>';\n  }).join('');\n}\n\nfunction renderAudit() {\n  var el = document.getElementById('audit-rows');\n  document.getElementById('audit-count').textContent = AUDIT_EVENTS.length + ' events';\n  if (AUDIT_EVENTS.length === 0) { el.innerHTML = '<div class=\"empty\">No events</div>'; return; }\n  el.innerHTML = AUDIT_EVENTS.slice(0,20).map(function(ev) {\n    var cls = ev.kind==='published'?'ev-pub':ev.kind==='witnessed'?'ev-wit':'ev-cha';\n    var label = ev.kind==='published'?'Published':ev.kind==='witnessed'?'Witnessed':'Challenged';\n    return '<div class=\"event-row\">'+\n      '<span class=\"ev-kind '+cls+'\">'+label+'</span>'+\n      '<span class=\"ev-dig\">'+short(ev.dig)+'</span>'+\n      '<span class=\"ev-data\">'+JSON.stringify(ev.data||{}).slice(0,80)+'</span>'+\n      '<span class=\"ev-time\">'+timeStr(ev.ts)+'</span>'+\n      '</div>';\n  }).join('');\n}\n\nfunction loadGraph(dig) {\n  get('/graph/claim/'+dig, function(g) {\n    if (!g || !g.ok) return;\n    var panel = document.getElementById('graph-panel');\n    document.getElementById('graph-digest').textContent = short(dig);\n    var html = '';\n    html += '<div class=\"kv-row\"><div class=\"kv-k\">Subject</div><div class=\"kv-v\">'+g.claim.subject+'</div></div>';\n    html += '<div class=\"kv-row\"><div class=\"kv-k\">Space</div><div class=\"kv-v\">'+g.claim.claim_space+'</div></div>';\n    html += '<div class=\"kv-row\"><div class=\"kv-k\">Value</div><div class=\"kv-v\">'+g.claim.object+'</div></div>';\n    html += '<div class=\"kv-row\"><div class=\"kv-k\">Issuer</div><div class=\"kv-v\">'+short(g.issuer_node_id)+'</div></div>';\n    html += '<div class=\"kv-row\"><div class=\"kv-k\">Witnesses</div><div class=\"kv-v\" style=\"color:var(--accent)\">'+g.witness_count+'</div></div>';\n    html += '<div class=\"kv-row\"><div class=\"kv-k\">Challenges</div><div class=\"kv-v\" style=\"color:var(--warn)\">'+g.challenge_count+'</div></div>';\n    html += '<div class=\"kv-row\"><div class=\"kv-k\">Competing</div><div class=\"kv-v\">'+g.competing_count+'</div></div>';\n    if (g.witnesses && g.witnesses.length > 0) {\n      g.witnesses.forEach(function(w) {\n        html += '<div class=\"kv-row\"><div class=\"kv-k\" style=\"font-size:10px\">Witness: '+w.validation_type+'</div><div class=\"kv-v\" style=\"font-size:10px\">'+short(w.witness_node_id)+'</div></div>';\n      });\n    }\n    document.getElementById('graph-content').innerHTML = html;\n    panel.style.display = 'block';\n  });\n}\n\ndocument.addEventListener('click', function(e){ if(e.target.id==='graph-close') document.getElementById('graph-panel').style.display='none'; });\nload();\nsetInterval(function(){AUDIT_EVENTS=[];load();}, 8000);\n</script>\n</body>\n</html>"
}

export { html }
