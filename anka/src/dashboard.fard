fn html() {
  "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>ANKA Node</title>\n<style>\n@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&display=swap');\n:root{--bg:#09090b;--surface:#111113;--border:#1c1c1f;--text:#a1a1aa;--bright:#e4e4e7;--accent:#00c896;--warn:#f59e0b;--error:#ef4444;--mono:'IBM Plex Mono',monospace;}\n*{box-sizing:border-box;margin:0;padding:0;}\nbody{background:var(--bg);color:var(--text);font-family:var(--mono);font-size:12.5px;line-height:1.65;min-height:100vh;}\nheader{border-bottom:1px solid var(--border);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--bg);z-index:100;}\n.logo{font-size:13px;font-weight:500;color:var(--accent);letter-spacing:.2em;text-transform:uppercase;}\n.hright{display:flex;align-items:center;gap:20px;}\n.dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:pulse 2.5s infinite;}\n@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.25;}}\n.node-id{font-size:11px;color:#3f3f46;max-width:380px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\nmain{padding:28px;max-width:1100px;margin:0 auto;}\n.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-bottom:28px;}\n.stat{background:var(--surface);padding:18px 22px;}\n.stat-label{font-size:10px;color:#3f3f46;text-transform:uppercase;letter-spacing:.14em;margin-bottom:6px;}\n.stat-value{font-size:26px;font-weight:300;color:var(--bright);line-height:1;}\n.stat-value.a{color:var(--accent);}\n.sec{margin-bottom:28px;}\n.sec-head{font-size:10px;text-transform:uppercase;letter-spacing:.15em;color:#3f3f46;border-bottom:1px solid var(--border);padding-bottom:7px;margin-bottom:12px;display:flex;justify-content:space-between;}\n.sec-head em{color:var(--accent);font-style:normal;}\n.rows{display:flex;flex-direction:column;gap:1px;background:var(--border);border:1px solid var(--border);}\n.row{background:var(--surface);padding:9px 14px;font-size:11.5px;}\n.row:hover{background:#16161a;}\n.digest{color:var(--accent);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n.spaces{display:flex;flex-wrap:wrap;gap:6px;}\n.space-tag{font-size:10px;padding:3px 9px;border:1px solid var(--accent);color:var(--accent);border-radius:2px;}\n.empty{color:#3f3f46;padding:16px 14px;font-size:11px;}\n.two{display:grid;grid-template-columns:1fr 1fr;gap:28px;}\n.refresh{font-size:10px;color:#3f3f46;cursor:pointer;text-transform:uppercase;letter-spacing:.1em;border:none;background:none;font-family:var(--mono);}\n.refresh:hover{color:var(--accent);}\n.kv{display:flex;flex-direction:column;gap:1px;background:var(--border);border:1px solid var(--border);}\n.kv-row{background:var(--surface);padding:8px 14px;display:grid;grid-template-columns:140px 1fr;gap:12px;font-size:11.5px;}\n.kv-k{color:#3f3f46;}\n.kv-v{color:var(--bright);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n</style>\n</head>\n<body>\n<header>\n  <div class=\"logo\">&#9632; ANKA</div>\n  <div class=\"hright\">\n    <div class=\"node-id\" id=\"node-id\">connecting...</div>\n    <div class=\"dot\" id=\"dot\" style=\"background:#3f3f46\"></div>\n  </div>\n</header>\n<main>\n  <div class=\"grid\">\n    <div class=\"stat\"><div class=\"stat-label\">Claims</div><div class=\"stat-value a\" id=\"s-claims\">-</div></div>\n    <div class=\"stat\"><div class=\"stat-label\">Witnesses</div><div class=\"stat-value\" id=\"s-witnesses\">-</div></div>\n    <div class=\"stat\"><div class=\"stat-label\">Challenges</div><div class=\"stat-value\" id=\"s-challenges\">-</div></div>\n    <div class=\"stat\"><div class=\"stat-label\">Known Digests</div><div class=\"stat-value\" id=\"s-known\">-</div></div>\n  </div>\n  <div class=\"two\">\n    <div class=\"sec\">\n      <div class=\"sec-head\"><span>Node Identity</span></div>\n      <div class=\"kv\" id=\"identity-table\"><div class=\"empty\">loading...</div></div>\n    </div>\n    <div class=\"sec\">\n      <div class=\"sec-head\"><span>Registry</span><em id=\"reg-version\"></em></div>\n      <div class=\"spaces\" id=\"spaces\"><div class=\"empty\">loading...</div></div>\n    </div>\n  </div>\n  <div class=\"sec\">\n    <div class=\"sec-head\">\n      <span>Known Digests</span>\n      <button class=\"refresh\" onclick=\"load()\">refresh</button>\n    </div>\n    <div class=\"rows\" id=\"digest-list\"><div class=\"empty\">loading...</div></div>\n  </div>\n  <div class=\"two\">\n    <div class=\"sec\">\n      <div class=\"sec-head\"><span>Audit</span></div>\n      <div class=\"kv\" id=\"audit-table\"><div class=\"empty\">loading...</div></div>\n    </div>\n    <div class=\"sec\">\n      <div class=\"sec-head\"><span>Peers</span></div>\n      <div class=\"rows\" id=\"peer-list\"><div class=\"empty\">loading...</div></div>\n    </div>\n  </div>\n</main>\n<script>\nvar BASE = window.location.origin;\nfunction get(path, cb) {\n  fetch(BASE + path).then(function(r){ return r.json(); }).then(cb).catch(function(){});\n}\nfunction kvRows(pairs) {\n  return pairs.map(function(p){\n    return '<div class=\"kv-row\"><div class=\"kv-k\">'+p[0]+'</div><div class=\"kv-v\">'+p[1]+'</div></div>';\n  }).join('');\n}\nfunction load() {\n  get('/health', function(h) {\n    if (!h) return;\n    document.getElementById('dot').style.background = 'var(--accent)';\n    document.getElementById('node-id').textContent = h.node_id || '';\n    document.getElementById('identity-table').innerHTML = kvRows([['node_id', h.node_id || '-']]);\n  });\n  get('/sync', function(s) {\n    if (!s) return;\n    document.getElementById('s-claims').textContent = s.claim_count;\n    document.getElementById('s-witnesses').textContent = s.witness_count;\n    document.getElementById('s-challenges').textContent = s.challenge_count;\n  });\n  get('/known', function(k) {\n    if (!k) return;\n    var d = k.known_digests || [];\n    document.getElementById('s-known').textContent = d.length;\n    var el = document.getElementById('digest-list');\n    if (d.length === 0) { el.innerHTML = '<div class=\"empty\">no claims yet</div>'; return; }\n    el.innerHTML = d.slice(0,50).map(function(x){ return '<div class=\"row\"><div class=\"digest\">'+x+'</div></div>'; }).join('');\n  });\n  get('/registry', function(r) {\n    if (!r) return;\n    var sp = r.known_spaces || [];\n    document.getElementById('reg-version').textContent = r.registry ? 'v'+r.registry.version : '';\n    var el = document.getElementById('spaces');\n    if (sp.length === 0) { el.innerHTML = '<div class=\"empty\">no spaces</div>'; return; }\n    el.innerHTML = sp.map(function(s){ return '<span class=\"space-tag\">'+s+'</span>'; }).join('');\n  });\n  get('/audit', function(a) {\n    if (!a) return;\n    document.getElementById('audit-table').innerHTML = kvRows([\n      ['snapshots', a.snapshot_count],\n      ['receipts', a.receipt_count]\n    ]);\n  });\n  get('/peers', function(p) {\n    if (!p) return;\n    var pl = p.peers || [];\n    var el = document.getElementById('peer-list');\n    if (pl.length === 0) { el.innerHTML = '<div class=\"empty\">no peers</div>'; return; }\n    el.innerHTML = pl.map(function(x){ return '<div class=\"row\"><div class=\"digest\">'+x+'</div></div>'; }).join('');\n  });\n}\nload();\nsetInterval(load, 10000);\n</script>\n</body>\n</html>\n"
}

export { html }
