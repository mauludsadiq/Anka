import("std/http") as http
import("std/json") as json
import("std/str") as str
import("std/list") as list
import("std/rec") as rec
import("std/int") as int

// Risk Agent
// Role: challenge overconfident forecasts, witness well-calibrated ones.
// Publishes to: risk.assessment.claims
//
// Deliberation logic:
//   - Parse confidence from finding: "... | confidence:85 | ..."
//   - If confidence > high_threshold (e.g. 85): challenge (overconfident)
//   - If confidence <= high_threshold and has receipt ref: witness
//   - If no receipt ref: challenge (unverifiable)
//   - Already seen: ignore

fn make_dalil(node_address) {
  {
    feed: fn(addr, claim_spaces, since_ts) {
      let known = http.get(str.concat([addr, "/known"])) in
      if known.status != 200 then { ok: false, claims: [] }
      else
        let kd = json.decode(known.body) in
        let claims = list.fold(kd.known_digests, [], fn(acc, digest) {
          let r = http.get(str.concat([addr, "/claim/", digest])) in
          if r.status != 200 then acc
          else
            let env = json.decode(r.body).envelope in
            let in_space = list.any(claim_spaces, fn(cs) { cs == env.claim.claim_space }) in
            if !in_space then acc
            else if env.claim.timestamp_unix_secs <= since_ts then acc
            else list.append(acc, {
              digest_hex: digest,
              claim_space: env.claim.claim_space,
              subject: env.claim.subject,
              finding: env.claim.object,
              evidence_refs: env.claim.evidence_refs,
              score: 0,
              issuer: env.claim.issuer_node_id,
              timestamp: env.claim.timestamp_unix_secs
            })
        }) in
        { ok: true, claims: claims }
    },
    post_node: fn(addr, path, body) {
      let result = http.post(str.concat([addr, path]), json.encode(body)) in
      if result.status == 200 then { ok: true, data: json.decode(result.body) }
      else { ok: false }
    },
    compose: fn(addr, cs, subj, finding, refs, ts) {
      let result = http.post(str.concat([addr, "/publish"]), json.encode({
        claim_space: cs, subject: subj, predicate: "reported_finding",
        object: finding, evidence_refs: refs, timestamp_unix_secs: ts
      })) in
      if result.status == 200 then
        let d = json.decode(result.body) in
        { ok: true, digest_hex: d.digest_hex }
      else { ok: false }
    }
  }
}

fn parse_confidence(finding) {
  if str.contains(finding, "confidence:") then
    let parts = str.split(finding, "confidence:") in
    if list.len(parts) < 2 then 50
    else
      let after = list.get(parts, 1) in
      let num_parts = str.split(after, " ") in
      let num_str = str.split(list.head(num_parts), "|") in
      let parsed = int.parse(str.trim(list.head(num_str))) in
      if parsed.t == "ok" then parsed.v else 50
  else 50
}

fn has_receipt_ref(claim) {
  list.len(claim.evidence_refs) > 0
}

fn deliberate(claim, seen_digests, high_confidence_threshold) {
  let digest = claim.digest_hex in
  if rec.has(seen_digests, digest) then
    { action: "ignore", reason: "already seen", digest: digest }
  else if claim.claim_space != "market.forecast.claims" then
    { action: "ignore", reason: "not a forecast", digest: digest }
  else if !has_receipt_ref(claim) then
    { action: "challenge", reason: "forecast has no computation receipt", digest: digest }
  else
    let confidence = parse_confidence(claim.finding) in
    if confidence > high_confidence_threshold then
      { action: "challenge", reason: str.concat(["overconfident forecast: ", str.from(confidence), "% confidence"]), digest: digest }
    else
      { action: "witness", reason: str.concat(["well-calibrated forecast: ", str.from(confidence), "% confidence"]), digest: digest }
}

fn publish_risk_assessment(dalil, node_address, claim, delib, timestamp) {
  let confidence = parse_confidence(claim.finding) in
  let risk_level = if confidence > 85 then "HIGH_RISK"
    else if confidence > 70 then "MODERATE_RISK"
    else "LOW_RISK" in
  let assessment = str.concat([risk_level, " on ", claim.subject, ": confidence=", str.from(confidence), "% — ", delib.reason]) in
  dalil.compose(node_address, "risk.assessment.claims", claim.subject, assessment, [claim.digest_hex], timestamp)
}

fn run(node_address, institution, since_ts, timestamp, high_confidence_threshold) {
  let dalil = make_dalil(node_address) in
  let feed = dalil.feed(node_address, ["market.forecast.claims"], since_ts) in
  if !feed.ok then { ok: false, reason: "feed failed" }
  else
    let result = list.fold(feed.claims, { witnessed: 0, challenged: 0, assessed: 0, seen: {} }, fn(acc, claim) {
      let delib = deliberate(claim, acc.seen, high_confidence_threshold) in
      let next_seen = rec.set(acc.seen, claim.digest_hex, true) in
      if delib.action == "witness" then
        let _ = dalil.post_node(node_address, "/witness", {
          digest_hex: claim.digest_hex,
          witness_node_id: str.concat([institution, "-risk-agent"]),
          validation_type: "risk_calibration_verified",
          timestamp_unix_secs: timestamp
        }) in
        let _ = publish_risk_assessment(dalil, node_address, claim, delib, timestamp) in
        { witnessed: acc.witnessed + 1, challenged: acc.challenged, assessed: acc.assessed + 1, seen: next_seen }
      else if delib.action == "challenge" then
        let _ = dalil.post_node(node_address, "/challenge", {
          target_digest_hex: claim.digest_hex,
          challenger_node_id: str.concat([institution, "-risk-agent"]),
          kind: "overconfidence",
          reasoning: delib.reason,
          challenger_signature_hex: "sig",
          timestamp_unix_secs: timestamp
        }) in
        let _ = publish_risk_assessment(dalil, node_address, claim, delib, timestamp) in
        { witnessed: acc.witnessed, challenged: acc.challenged + 1, assessed: acc.assessed + 1, seen: next_seen }
      else
        { ...acc, seen: next_seen }
    }) in
    {
      ok: true,
      agent: "risk",
      institution: institution,
      observed: list.len(feed.claims),
      witnessed: result.witnessed,
      challenged: result.challenged,
      assessed: result.assessed
    }
}

export { make_dalil, parse_confidence, has_receipt_ref, deliberate, publish_risk_assessment, run }
