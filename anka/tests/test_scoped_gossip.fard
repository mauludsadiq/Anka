import("../src/scoped_gossip") as sg
import("../src/node") as node
import("../src/transport") as transport
import("std/list") as list

test "subscription matches declared space" {
  let sub = sg.subscription_add(sg.subscription_empty(), "econ.space") in
  sg.subscription_matches(sub, "econ.space") && !sg.subscription_matches(sub, "crypto.space")
}

test "wildcard subscription matches all spaces" {
  let sub = sg.subscription_all() in
  sg.subscription_matches(sub, "econ.space") && sg.subscription_matches(sub, "crypto.space")
}

test "scoped sync plan excludes out-of-scope digests" {
  let a0 = node.new_node("scope-a") in
  let b0 = node.new_node("scope-b") in
  let pub_econ = node.publish(a0, "econ.space", "GDP", "forecast", "2.3", [], 100) in
  let pub_crypto = node.publish(pub_econ.node, "crypto.space", "BTC", "price", "50000", [], 101) in
  let sub_econ_only = sg.subscription_add(sg.subscription_empty(), "econ.space") in
  let plan = sg.scoped_sync_plan(pub_crypto.node, b0, sub_econ_only) in
  plan.count == 1
}

test "scoped gossip only sends subscribed spaces" {
  let a0 = node.new_node("scope-a2") in
  let b0 = node.new_node("scope-b2") in
  let pub_econ = node.publish(a0, "econ.space", "GDP", "forecast", "2.3", [], 100) in
  let pub_crypto = node.publish(pub_econ.node, "crypto.space", "BTC", "price", "50000", [], 101) in
  let peer_book = transport.peer_book_add(transport.peer_book_empty(), transport.peer(pub_crypto.node.node_id, pub_crypto.node.node_secret)) in
  let sub_econ_only = sg.subscription_add(sg.subscription_empty(), "econ.space") in
  let result = sg.scoped_gossip_once(pub_crypto.node, b0, sub_econ_only, peer_book, 102) in
  result.sent_count == 1 && result.filtered_count == 1
}

test "node with wildcard subscription receives all spaces" {
  let a0 = node.new_node("scope-a3") in
  let b0 = node.new_node("scope-b3") in
  let pub_econ = node.publish(a0, "econ.space", "GDP", "forecast", "2.3", [], 100) in
  let pub_crypto = node.publish(pub_econ.node, "crypto.space", "BTC", "price", "50000", [], 101) in
  let peer_book = transport.peer_book_add(transport.peer_book_empty(), transport.peer(pub_crypto.node.node_id, pub_crypto.node.node_secret)) in
  let sub_all = sg.subscription_all() in
  let result = sg.scoped_gossip_once(pub_crypto.node, b0, sub_all, peer_book, 102) in
  result.sent_count == 2 && result.filtered_count == 0
}

test "multi-space subscription receives only declared spaces" {
  let a0 = node.new_node("scope-a4") in
  let b0 = node.new_node("scope-b4") in
  let pub_econ = node.publish(a0, "econ.space", "GDP", "forecast", "2.3", [], 100) in
  let pub_crypto = node.publish(pub_econ.node, "crypto.space", "BTC", "price", "50000", [], 101) in
  let pub_geo = node.publish(pub_crypto.node, "geo.space", "conflict", "status", "active", [], 102) in
  let peer_book = transport.peer_book_add(transport.peer_book_empty(), transport.peer(pub_geo.node.node_id, pub_geo.node.node_secret)) in
  let sub = sg.subscription_add(sg.subscription_add(sg.subscription_empty(), "econ.space"), "crypto.space") in
  let result = sg.scoped_gossip_once(pub_geo.node, b0, sub, peer_book, 103) in
  result.sent_count == 2 && result.filtered_count == 1
}
