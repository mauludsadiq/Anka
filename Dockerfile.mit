FROM ubuntu:22.04

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

COPY fardrun /usr/local/bin/fardrun
RUN chmod +x /usr/local/bin/fardrun

WORKDIR /app
COPY anka/ anka/

RUN mkdir -p out/node

EXPOSE 18081

HEALTHCHECK --interval=5s --timeout=3s --retries=5 --start-period=10s \
  CMD curl -f http://localhost:18081/health || exit 1

CMD ["fardrun", "run", "--program", "anka/src/node_process_b.fard", "--out", "out/node"]
